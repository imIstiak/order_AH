{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": false,
    "noImplicitAny": false,
    "allowJs": false,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true
  },
  "include": ["**/*.ts", "**/*.tsx", "vite-env.d.ts"],
  "exclude": [
    "dist",
    "node_modules",
    "admin-coupons.tsx",
    "admin-batch-detail.tsx",
    "admin-order-management.tsx",
    "admin-new-order-form.tsx",
    "admin-products.tsx",
    "admin-preorders-pipeline.tsx",
    "admin-remittance.tsx"
  ]
}
